<Window x:Class="Cyber.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <!-- WINDOW BACKGROUND -->
    <Window.Background>
        <ImageBrush ImageSource="/back.png"
                    Stretch="UniformToFill"
                    Opacity="0.35"/>
    </Window.Background>

    <Grid Margin="15">

        <!-- ROW DEFINITIONS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#CC007ACC"
                CornerRadius="20"
                Padding="15"
                Margin="0,0,0,15">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <TextBlock Text="🛡"
                           FontSize="36"
                           Margin="0,0,10,0"/>

                <TextBlock Text="CYBERSECURITY AWARENESS BOT"
                           Foreground="White"
                           FontSize="30"
                           FontWeight="Bold"
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- CHAT AREA -->
        <Border Grid.Row="1"
                Background="#DD1E1E1E"
                CornerRadius="20"
                Padding="10"
                Margin="0,0,0,15">

            <ScrollViewer x:Name="ChatScroll"
                          VerticalScrollBarVisibility="Auto">

                <TextBox x:Name="ChatBox"
                         Background="#252526"
                         Foreground="White"
                         FontFamily="Segoe UI"
                         FontSize="16"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         BorderThickness="0"
                         Padding="15"
                         VerticalScrollBarVisibility="Hidden"/>
            </ScrollViewer>
        </Border>

        <!-- INPUT AREA -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <!-- INPUT BOX -->
            <Border Grid.Column="0"
                    Background="#DD333333"
                    CornerRadius="15"
                    Margin="0,0,10,0">

                <TextBox x:Name="UserInputBox"
                         Background="#333333"
                         Foreground="White"
                         BorderThickness="0"
                         FontSize="16"
                         FontFamily="Segoe UI"
                         Padding="15"
                         VerticalContentAlignment="Center"
                         KeyDown="UserInputBox_KeyDown"/>
            </Border>

            <!-- SEND BUTTON -->
            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Content="SEND"
                    FontSize="18"
                    FontWeight="Bold"
                    Background="#007ACC"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="SendButton_Click">

                <Button.Style>
                    <Style TargetType="Button">

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">

                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="15">

                                        <ContentPresenter
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>

                                    </Border>

                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>

                        <!-- HOVER -->
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#0099FF"/>
                            </Trigger>
                        </Style.Triggers>

                    </Style>
                </Button.Style>

            </Button>

        </Grid>

    </Grid>

</Window>